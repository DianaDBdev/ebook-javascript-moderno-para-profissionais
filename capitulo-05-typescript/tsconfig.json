{
  "compilerOptions": {
    /* Qual JavaScript gerar */
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Onde colocar o output */
    "outDir": "./dist",
    "rootDir": "./src",

    /* Rigor — recomendado ativar tudo em projetos novos */
    "strict": true,

    /* Interoperabilidade */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Source maps para debug */
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
