{
  "name": "cap06-code-quality",
  "type": "module",
  "scripts": {
    "lint":          "eslint src --max-warnings 0",
    "lint:fix":      "eslint src --fix",
    "lint:ci":       "eslint src --max-warnings 0",
    "format":        "prettier --write \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "format:check":  "prettier --check \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "typecheck":     "tsc --noEmit",
    "test":          "vitest run",
    "quality":       "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare":       "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint":                          "^9.0.0",
    "@eslint/js":                      "^9.0.0",
    "typescript-eslint":               "^8.0.0",
    "eslint-plugin-react":             "^7.0.0",
    "eslint-plugin-react-hooks":       "^5.0.0",
    "eslint-plugin-jsx-a11y":          "^6.0.0",
    "eslint-config-prettier":          "^9.0.0",
    "prettier":                        "^3.0.0",
    "husky":                           "^9.0.0",
    "lint-staged":                     "^15.0.0",
    "@commitlint/cli":                 "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  }
}
