# .editorconfig — Seção 6.4: Configuração compartilhada de editor
# Capítulo 6 — Linting, Formatting e Code Quality
#
# Suportado por VS Code, IntelliJ, Vim, Emacs e quase todos os editores
# sem plugin adicional.

root = true

[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = true
insert_final_newline     = true

[*.md]
trim_trailing_whitespace = false  # Markdown usa espaços para quebra de linha

[Makefile]
indent_style             = tab    # Makefiles exigem tab
