{
  "name": "setup-code-quality",
  "version": "1.0.0",
  "type": "module",
  "description": "Template de setup completo — Cap. 6",
  "scripts": {
    "lint":       "eslint . --ext .ts,.js",
    "lint:fix":   "eslint . --ext .ts,.js --fix",
    "format":     "prettier --write .",
    "format:check":"prettier --check .",
    "prepare":    "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
